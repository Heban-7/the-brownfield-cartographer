# Environment configuration for The Brownfield Cartographer

# Core API key for all OpenRouter calls
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model used by Semanticist for bulk module summaries & clustering
# Example: openrouter/google/gemini-flash-1.5
OPENROUTER_BULK_MODEL=your_bulk_model_id_here

# Model used by Semanticist for synthesis / Day-One style reasoning
# Example: openrouter/openai/gpt-4o-mini
OPENROUTER_SYNTH_MODEL=your_synth_model_id_here

# Model used by Navigator's `explain_module` command
# Example: openrouter/openai/gpt-4o-mini
OPENROUTER_EXPLAIN_MODEL=your_explain_model_id_here
